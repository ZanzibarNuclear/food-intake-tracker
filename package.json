{
  "name": "food-intake-tracker",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 127.0.0.1",
    "db:setup": "node scripts/setup-db.mjs",
    "generate:seed": "python3 tools/extract_seed.py \"docs/original/Daily Intake - 2026-06-28.xlsx\" server/data/seed.json",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "nuxt": "^4.2.2",
    "pg": "^8.16.3",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.8"
  }
}
