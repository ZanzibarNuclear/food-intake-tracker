{
  "name": "food-intake-tracker",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host 127.0.0.1",
    "auth:migrate": "npx auth@latest migrate",
    "db:migrate": "node scripts/migrate-db.mjs",
    "db:seed:catalog": "node scripts/seed-catalog.mjs",
    "db:seed:user": "node scripts/seed-user-data.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed:catalog",
    "generate:seed": "python3 tools/extract_seed.py \"docs/original/Daily Intake - 2026-06-28.xlsx\" server/data/seed.json",
    "generate:catalog": "node tools/build_system_foods.mjs",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "better-auth": "^1.6.23",
    "chart.js": "^4.5.1",
    "dotenv": "^17.4.2",
    "nuxt": "^4.2.2",
    "pg": "^8.16.3",
    "resend": "^6.16.0",
    "vue": "^3.5.24",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.0.10",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "vue-tsc": "^3.1.8"
  }
}
